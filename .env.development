# Enable video preloading (Phase 1 — safe videos only).
# Remove or set to 0 to disable. Never set in .env.production unless tested.
VITE_VIDEO_PRELOAD=1

# Runner JSON-RPC endpoint for local dev.
# Points at the Go backend's dev-runner shim (requires ENABLE_DEV_RUNNER=1 on the server).
# In production the Runner URL is relative (/api) — the default in runnerClient.ts.
VITE_RUNNER_URL=http://localhost:4051/dev-api
